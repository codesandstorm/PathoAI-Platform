# PathoAI-Platform .gitignore
# Comprehensive exclusions for research ML project
# Last updated: 2026-07-18 — see CONTRIBUTING.md §3 for full policy

# ── Whole Slide Images (never in Git — these are gigabyte-scale files) ────────
*.svs
*.ndpi
*.scn
*.mrxs
*.vms
*.vmu
*.bif
# Note: .tif/.tiff excluded below to avoid blocking config or test TIFFs by
# extension alone — rely on data/ / models/ directory rules instead.

# ── Data (too large for git) ──────────────────────────────────────────────────
data/
!data/.gitkeep

# ── Model Checkpoints & Weights (too large) ─────────────────────────────────
models/
!models/.gitkeep
*.pth
*.pt
*.ckpt
*.pkl
*.onnx
*.safetensors

# ── Checkpoints directory ────────────────────────────────────────────────────
checkpoints/
!checkpoints/.gitkeep

# ── Outputs (generated artifacts — reproducible from code) ───────────────────
outputs/
!outputs/.gitkeep

# ── Pipeline Results (reproducible from code) ────────────────────────────────
results/
!results/.gitkeep

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
!logs/.gitkeep
*.log
# JSONL experiment logs (not test fixtures)
logs/**/*.jsonl

# ── Python Artifacts ─────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
.eggs/
parts/
var/
sdist/
wheels/
pip-wheel-metadata/
share/python-wheels/
.installed.cfg
lib/
lib64/
MANIFEST

# ── Virtual Environments ─────────────────────────────────────────────────────
.env
venv/
.venv/
env/
ENV/
pathoai_env/
*.env

# ── Environment Variables (contains secrets) ──────────────────────────────────
.env
.env.local
.env.production

# ── Jupyter Notebooks (keep .ipynb files, strip cell outputs) ────────────────
.ipynb_checkpoints/
# Notebook outputs are stripped with nbstripout — commit clean notebooks only

# ── IDE Configuration ────────────────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo
*~
.project
.pydevproject

# ── Testing Artifacts ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
nosetests.xml
test_output/

# ── TensorBoard ──────────────────────────────────────────────────────────────
runs/
tensorboard_logs/
tb_logs/

# ── OS Artifacts ─────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Splits / Fold definitions (generated, not source) ───────────────────────
splits/
!splits/.gitkeep

# ── Cache directories ────────────────────────────────────────────────────────
.cache/
cache/

# ── Large Archive Files ──────────────────────────────────────────────────────
*.zip
*.tar
*.gz
*.tar.gz
*.tar.bz2
*.7z
*.bz2
*.xz

# ── Large Intermediate Files ─────────────────────────────────────────────────
*.npy
*.npz
*.hdf5
*.h5

# ── WSI / Medical Imaging Formats (belt-and-suspenders on top of dir rules) ──
*.tif
*.tiff

# ── Documentation Build ──────────────────────────────────────────────────────
docs/_build/
docs/api/

# ── Profiling ────────────────────────────────────────────────────────────────
*.prof
*.lprof

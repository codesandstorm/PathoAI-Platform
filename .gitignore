# PathoAI-Platform .gitignore
# Comprehensive exclusions for research ML project

# ── Data (too large for git) ──────────────────────────────────────────────────
data/raw/
data/processed/
!data/.gitkeep

# ── Model Checkpoints (too large) ────────────────────────────────────────────
models/pretrained/
models/trained/
!models/.gitkeep
*.pth
*.pt
*.ckpt
*.pkl

# ── Pipeline Results (reproducible from code) ────────────────────────────────
results/
!results/.gitkeep

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
!logs/.gitkeep
*.log
*.jsonl

# ── Python Artifacts ─────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
.eggs/
parts/
var/
sdist/
wheels/
pip-wheel-metadata/
share/python-wheels/
.installed.cfg
lib/
lib64/
MANIFEST

# ── Virtual Environments ─────────────────────────────────────────────────────
.env
venv/
.venv/
env/
ENV/
pathoai_env/
*.env

# ── Environment Variables (contains secrets) ──────────────────────────────────
.env
.env.local
.env.production

# ── Jupyter Notebooks (keep .ipynb files, strip cell outputs) ────────────────
.ipynb_checkpoints/
# Notebook outputs are stripped with nbstripout — commit clean notebooks only

# ── IDE Configuration ────────────────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo
*~
.project
.pydevproject

# ── Testing Artifacts ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
nosetests.xml
test_output/

# ── TensorBoard ──────────────────────────────────────────────────────────────
runs/
tensorboard_logs/
tb_logs/

# ── OS Artifacts ─────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Large Intermediate Files ─────────────────────────────────────────────────
*.npy
*.npz
*.hdf5
*.h5

# ── Documentation Build ──────────────────────────────────────────────────────
docs/_build/
docs/api/

# ── Profiling ────────────────────────────────────────────────────────────────
*.prof
*.lprof
